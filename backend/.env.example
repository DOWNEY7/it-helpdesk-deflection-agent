# ─────────────────────────────────────────────────────────────────
#  IT Helpdesk Deflection Agent — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────

# ── Azure OpenAI ──────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Azure AI Search ───────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=https://<your-resource>.search.windows.net
AZURE_SEARCH_API_KEY=<your-api-key>
AZURE_SEARCH_INDEX_NAME=helpdesk-kb

# ── Application Settings ─────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.70          # below this → escalate
LOW_CONFIDENCE_THRESHOLD=0.85      # below this → answer with disclaimer
MAX_RETRIEVAL_CHUNKS=5
MAX_INPUT_CHARS=2000
MAX_OUTPUT_TOKENS=600
REQUEST_TIMEOUT_SECONDS=15
ENVIRONMENT=development            # development | staging | production

# ── Security ─────────────────────────────────────────────────────
SESSION_SECRET_KEY=<random-32-char-string-change-this>
RATE_LIMIT_PER_SESSION=20          # requests per window
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_PER_IP=100
RATE_LIMIT_IP_WINDOW_SECONDS=600

# ── Mock Mode (no Azure credentials needed for local dev) ─────────
# Set to "true" to use local KB files + simple keyword matching
MOCK_MODE=false

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
AUDIT_LOG_PATH=./logs/audit.jsonl
APP_LOG_PATH=./logs/app.jsonl
